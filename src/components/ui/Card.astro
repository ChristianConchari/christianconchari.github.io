---
interface Props extends astroHTML.JSX.HTMLAttributes {
  variant?: 'static' | 'lift' | 'glow';
  as?: 'div' | 'article';
  class?: string;
}

const { variant = 'static', as: Tag = 'div', class: className, ...rest } = Astro.props;

const variantClass =
  variant === 'lift'
    ? 'transition-all duration-300 hover:-translate-y-1 hover:shadow-lg'
    : variant === 'glow'
      ? 'transition-shadow duration-300 hover:shadow-md'
      : '';
---

<Tag
  class:list={[
    'dark:bg-navy-light/30 dark:border-navy-light rounded-lg border border-gray-200 bg-white p-6 shadow-sm',
    variantClass,
    className,
  ]}
  {...rest}
>
  <slot />
</Tag>
