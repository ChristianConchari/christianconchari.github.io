---
import SectionWrapper from '../layouts/SectionWrapper.astro';
import Icon from './Icon.astro';
import SectionHeading from './ui/SectionHeading.astro';
import Card from './ui/Card.astro';
import Tag from './ui/Tag.astro';

type ProjectCategory = 'AI & ML' | 'Backend' | 'Frontend' | 'Embedded' | 'Mobile';

interface Project {
  title: string;
  description: string;
  tags: string[];
  categories: ProjectCategory[];
  githubUrl: string;
  liveUrl?: string;
  image?: string;
}

const filterCategories: Array<'All' | ProjectCategory> = [
  'All',
  'AI & ML',
  'Backend',
  'Frontend',
  'Embedded',
  'Mobile',
];

const projects: Project[] = [
  {
    title: "AI Crop Emergence & Harvest Prediction",
    description: "Predictive model designed to identify critical agricultural stages using time-series analysis and satellite imagery for precision farming.",
    tags: ["Python", "Machine Learning", "Scikit-learn", "Remote Sensing"],
    categories: ["AI & ML"],
    githubUrl: "https://github.com/ChristianConchari/AI-Crop-Emergence-Harvest-Prediction",
    liveUrl: "#"
  },
  {
    title: "Distributed Edge Gait Recognition",
    description: "A framework for real-time, appearance-based biometric identification using distributed edge computing to minimize latency and bandwidth.",
    tags: ["Python", "Deep Learning", "Edge Computing", "PyTorch"],
    categories: ["AI & ML", "Embedded"],
    githubUrl: "https://github.com/ChristianConchari/Distributed-edge-computing-for-appearance-based-gait-recognition",
    liveUrl: "#"
  },
  {
    title: "Oil Painting Style Transfer",
    description: "An implementation of Neural Style Transfer (NST) to transform standard digital photographs into artistic oil paintings using deep learning frameworks.",
    tags: ["Python", "PyTorch", "Computer Vision", "Deep Learning"],
    categories: ["AI & ML"],
    githubUrl: "https://github.com/ChristianConchari/oil_painting_style_transfer",
    liveUrl: "#"
  },
  {
    title: "Bike Sharing Demand Analysis",
    description: "A comprehensive data science project focused on forecasting urban mobility demand through regression modeling and environmental data analysis.",
    tags: ["Python", "Data Analysis", "XGBoost", "Pandas"],
    categories: ["AI & ML"],
    githubUrl: "https://github.com/ChristianConchari/bike-sharing-demand",
    liveUrl: "#"
  },
  {
    title: "Stratospheric TinyML Imagery Classifier",
    description: "An optimized deep learning pipeline for Earth observation, specifically designed for low-power edge devices (TinyML) on stratospheric balloon missions.",
    tags: ["TinyML", "TensorFlow Lite", "Python", "Remote Sensing"],
    categories: ["AI & ML", "Embedded"],
    githubUrl: "https://github.com/ChristianConchari/Strathospheric-ballon-earth-observation-gathered-imagery-classification-through-TinyML",
    liveUrl: "#"
  },
];

---

<SectionWrapper id="projects">
  <SectionHeading number="04" title="Projects" />

  <!-- Category Filter Pills -->
  <div class="flex flex-wrap gap-3 mb-12">
    {filterCategories.map((category) => (
      <button
        data-filter={category}
        data-active={category === 'All' ? 'true' : 'false'}
        class="filter-pill"
      >
        {category}
      </button>
    ))}
  </div>

  <!-- Projects Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {projects.map((project) => (
      <Card
        as="article"
        variant="lift"
        data-categories={project.categories.join(',')}
        class="group overflow-hidden p-0"
      >
        <!-- Image Area -->
        <div class="relative h-48 overflow-hidden">
          {project.image ? (
            <>
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-primary/10 group-hover:opacity-0 transition-opacity duration-300" />
            </>
          ) : (
            <div class="w-full h-full bg-linear-to-br from-gray-100 to-gray-200 dark:from-navy-light dark:to-background-dark flex items-center justify-center">
              <Icon name="code-brackets" class="w-10 h-10 text-primary/30" />
            </div>
          )}
        </div>

        <!-- Card Body -->
        <div class="p-6">
          <!-- Title Row with Action Links -->
          <div class="flex items-start justify-between gap-4 mb-3">
            <h3 class="text-base font-bold text-text-light dark:text-text-dark group-hover:text-primary transition-colors duration-200 leading-snug">
              {project.title}
            </h3>
            <div class="flex items-center gap-2 shrink-0">
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`View ${project.title} source code on GitHub`}
                class="text-muted-light dark:text-muted-dark hover:text-primary transition-colors duration-200"
              >
                <Icon name="code-brackets" class="w-4 h-4" />
              </a>
              {project.liveUrl && (
                <a
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`View ${project.title} live site`}
                  class="text-muted-light dark:text-muted-dark hover:text-primary transition-colors duration-200"
                >
                  <Icon name="external-link" class="w-4 h-4" />
                </a>
              )}
            </div>
          </div>

          <!-- Description -->
          <p class="text-sm text-muted-light dark:text-muted-dark leading-relaxed mb-4">
            {project.description}
          </p>

          <!-- Tech Tags -->
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => <Tag variant="accent">{tag}</Tag>)}
          </div>
        </div>
      </Card>
    ))}
  </div>
</SectionWrapper>

<script>
  const filterButtons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const projectCards = document.querySelectorAll<HTMLElement>('[data-categories]');

  function applyFilter(selectedFilter: string): void {
    filterButtons.forEach((button) => {
      const isSelected = button.dataset.filter === selectedFilter;
      button.dataset.active = String(isSelected);
    });

    projectCards.forEach((card) => {
      const cardCategories = card.dataset.categories?.split(',') ?? [];
      const isVisible = selectedFilter === 'All' || cardCategories.includes(selectedFilter);
      card.style.display = isVisible ? '' : 'none';
    });
  }

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const filter = button.dataset.filter ?? 'All';
      applyFilter(filter);
    });
  });
</script>
