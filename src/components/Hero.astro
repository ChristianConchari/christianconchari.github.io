---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
import heroLogo from '../assets/hero-logo-v1.png';
import ScrollIndicator from './ScrollIndicator.astro';
---

<div class="h-full font-sans md:flex md:flex-col md:justify-center">
  <main class="relative flex h-full flex-col items-center justify-center">
    <section
      class="grid w-full max-w-350 grid-cols-1 items-center justify-center gap-4 px-16"
      id="heroTitleSection"
    >
      <div
        class="z-10 flex flex-col items-center text-center"
        id="heroTextContent"
      >
        <h1
          class="mt-14 font-mono text-2xl font-medium text-teal-500 md:mt-24 md:text-3xl"
          id="heroGreeting"
        >
          Hi! I'm <p
            class="my-5 text-5xl font-extrabold text-gray-800 md:my-8 md:w-150 md:text-8xl dark:text-gray-100"
          >
            Christian Conchari
          </p>
        </h1>

        <h3
          class="my-4 font-mono text-2xl font-medium text-teal-500 md:my-6 md:text-3xl"
          id="heroSubtitle"
        >
          Software Architect | ML Engineer
        </h3>

        <p
          class="text-md mt-8 max-w-2xl font-normal text-gray-800 md:mt-10 md:text-xl dark:text-gray-100"
          id="heroDescription"
        >
          I'm a <span class="text-teal-400">Software Architect</span> and <span
            class="text-teal-400"
          >
            ML Engineer
          </span> specializing in building robust web applications and machine learning
          solutions. With a passion for technology and innovation, I strive to create
          impactful digital experiences.
        </p>
      </div>
    </section>
    <section
      class="z-0 mt-8 flex items-center justify-center"
      id="heroButtonSection"
    >
      <a
        href="#contact"
        class="m-4 rounded bg-teal-500 px-6 py-3 font-mono text-white no-underline hover:bg-teal-600 md:mx-6"
        id="contactButton"
      >
        Contact Me
      </a>
      <a
        href="#projects"
        class="m-4 rounded border-2 border-teal-500 px-6 py-3 font-mono text-teal-500 no-underline hover:bg-teal-100 md:mx-6"
        id="portfolioButton"
      >
        View Portfolio
      </a>
    </section>
    <ScrollIndicator targetId="about" />
  </main>
</div>
