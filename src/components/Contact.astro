---
import Icon from './Icon.astro';
import SectionWrapper from '../layouts/SectionWrapper.astro';

const socialLinks = [
  { handle: '@christianconchari', icon: 'github',   href: 'https://github.com/christianconchari' },
  { handle: '@chrisconchari',     icon: 'linkedin', href: 'https://www.linkedin.com/in/chrisconchari' },
  { handle: '@ConchariChris',     icon: 'x',        href: 'https://x.com/ConchariChris' },
];

const topicTiles = [
  {
    icon: 'rocket',
    title: 'Research Collaboration',
    description: "Working on an interesting machine learning initiative or academic paper? Let's explore how we can team up.",
    subject: 'Research Collaboration',
  },
  {
    icon: 'megaphone',
    title: 'Speaking & Events',
    description: 'Interested in having me share insights on AI or architecture at your upcoming meetup or academic event?',
    subject: 'Speaking Engagement',
  },
  {
    icon: 'code-brackets',
    title: 'Tech Consulting',
    description: 'Need deep-dive advice on ML architectures or system design?',
    subject: 'Technical Consulting',
  },
  {
    icon: 'chat-bubble',
    title: 'Just Say Hi',
    description: "No specific agenda? I'm always down to connect with fellow builders and researchers.",
    subject: 'Hi there!',
  },
];
---

<SectionWrapper id="contact">
  <!-- Section Header -->
  <div class="flex items-center gap-4 mb-12">
    <h2 class="font-mono text-2xl md:text-3xl font-bold">
      <span class="text-teal-500">05.</span>
      <span class="ml-2 text-gray-800 dark:text-gray-100">Contact</span>
    </h2>
    <div class="flex-1 h-px bg-gray-300 dark:bg-navy-light max-w-xs"></div>
  </div>

  <!-- Two-column grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">

    <!-- Left Column -->
    <div>
      <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
        Looking for a collaborator on your next research project? Interested in having me speak at your tech event, or need consulting for an upcoming AI initiative?
      </p>
      <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
        I'm always open to connecting with fellow builders and sharing knowledge. I'll try my best to get back to you as soon as possible.
      </p>

      <!-- Glowing email card -->
      <div class="group relative mt-8">
        <div class="absolute -inset-0.5 bg-linear-to- from-teal-500/20 to-teal-500/40 rounded-xl blur opacity-20 group-hover:opacity-50 transition duration-700"></div>
        <div class="relative flex items-center gap-6 p-6 bg-white dark:bg-navy-light/30 border border-gray-200 dark:border-navy-light rounded-xl shadow-sm">
          <div class="flex items-center justify-center w-14 h-14 rounded-full bg-teal-500/10 text-teal-500 shrink-0">
            <Icon name="chat-bubble" class="w-6 h-6" />
          </div>
          <div>
            <p class="font-mono text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Send an Email</p>
            <a
              href="mailto:christian@conchari.com"
              class="font-mono font-bold text-teal-500 text-lg hover:underline underline-offset-4 transition-all"
            >
              christian@conchari.com
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column -->
    <div>
      <h3 class="font-sans text-2xl font-bold text-gray-800 dark:text-gray-100 mb-2">How can I help you?</h3>
      <p class="font-mono text-xs uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-8">
        Select a topic to start a conversation
      </p>

      <div class="grid grid-cols-2 gap-4">
        {topicTiles.map((tile) => (
          <a
            href={`mailto:christian@conchari.com?subject=${encodeURIComponent(tile.subject)}`}
            class="group p-6 bg-white dark:bg-navy-light/30 border border-gray-200 dark:border-navy-light rounded-xl hover:border-teal-500/50 hover:shadow-lg transition-all duration-300"
          >
            <Icon name={tile.icon} class="w-6 h-6 text-teal-500 mb-3" />
            <h4 class="font-sans font-bold text-gray-800 dark:text-gray-100 mb-2">{tile.title}</h4>
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-snug">{tile.description}</p>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Footer bar -->
  <div class="mt-20 pt-10 border-t border-gray-200 dark:border-navy-light flex flex-col md:flex-row items-center justify-between gap-6">
    <p class="font-mono text-xs text-gray-400 uppercase tracking-widest">
      &copy; 2025 Christian Conchari. All rights reserved.
    </p>
    <div class="flex items-center gap-3">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-2 px-3 py-1.5 rounded-full border border-gray-200 dark:border-navy-light hover:border-teal-500/60 dark:hover:border-teal-500/60 hover:bg-teal-500/5 transition-all duration-200"
        >
          <Icon name={link.icon} class="w-3.5 h-3.5 text-gray-400 group-hover:text-teal-500 transition-colors duration-200 shrink-0" />
          <span class="font-mono text-[10px] tracking-wide text-gray-400 group-hover:text-teal-500 transition-colors duration-200">
            {link.handle}
          </span>
        </a>
      ))}
    </div>
  </div>
</SectionWrapper>
