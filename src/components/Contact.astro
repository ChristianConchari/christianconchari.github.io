---
import Icon from './Icon.astro';
import SectionWrapper from '../layouts/SectionWrapper.astro';

const socialLinks = [
  {
    handle: '@christianconchari',
    icon: 'github',
    href: 'https://github.com/christianconchari',
  },
  {
    handle: '@chrisconchari',
    icon: 'linkedin',
    href: 'https://www.linkedin.com/in/chrisconchari',
  },
  { handle: '@ConchariChris', icon: 'x', href: 'https://x.com/ConchariChris' },
];

const topicTiles = [
  {
    icon: 'rocket',
    title: 'Research Collaboration',
    description:
      "Working on an interesting machine learning initiative or academic paper? Let's explore how we can team up.",
    subject: 'Research Collaboration',
  },
  {
    icon: 'megaphone',
    title: 'Speaking & Events',
    description:
      'Interested in having me share insights on AI or architecture at your upcoming meetup or academic event?',
    subject: 'Speaking Engagement',
  },
  {
    icon: 'code-brackets',
    title: 'Tech Consulting',
    description: 'Need deep-dive advice on ML architectures or system design?',
    subject: 'Technical Consulting',
  },
  {
    icon: 'chat-bubble',
    title: 'Just Say Hi',
    description:
      "No specific agenda? I'm always down to connect with fellow builders and researchers.",
    subject: 'Hi there!',
  },
];
---

<SectionWrapper id="contact">
  <!-- Section Header -->
  <div class="mb-12 flex items-center gap-4">
    <h2 class="font-mono text-2xl font-bold md:text-3xl">
      <span class="text-teal-500">05.</span>
      <span class="ml-2 text-gray-800 dark:text-gray-100">Contact</span>
    </h2>
    <div class="dark:bg-navy-light h-px max-w-xs flex-1 bg-gray-300"></div>
  </div>

  <!-- Two-column grid -->
  <div class="grid grid-cols-1 gap-16 lg:grid-cols-2 lg:gap-24">
    <!-- Left Column -->
    <div>
      <p class="mb-4 leading-relaxed text-gray-700 dark:text-gray-300">
        Looking for a collaborator on your next research project? Interested in
        having me speak at your tech event, or need consulting for an upcoming
        AI initiative?
      </p>
      <p class="leading-relaxed text-gray-700 dark:text-gray-300">
        I'm always open to connecting with fellow builders and sharing
        knowledge. I'll try my best to get back to you as soon as possible.
      </p>

      <!-- Glowing email card -->
      <div class="group relative mt-8">
        <div
          class="bg-linear-to- absolute -inset-0.5 rounded-xl from-teal-500/20 to-teal-500/40 opacity-20 blur transition duration-700 group-hover:opacity-50"
        >
        </div>
        <div
          class="dark:bg-navy-light/30 dark:border-navy-light relative flex items-center gap-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm"
        >
          <div
            class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-teal-500/10 text-teal-500"
          >
            <Icon name="chat-bubble" class="h-6 w-6" />
          </div>
          <div>
            <p
              class="mb-1 font-mono text-xs font-bold tracking-wider text-gray-400 uppercase"
            >
              Send an Email
            </p>
            <a
              href="mailto:christian@conchari.com"
              class="font-mono text-lg font-bold text-teal-500 underline-offset-4 transition-all hover:underline"
            >
              christian@conchari.com
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column -->
    <div>
      <h3
        class="mb-2 font-sans text-2xl font-bold text-gray-800 dark:text-gray-100"
      >
        How can I help you?
      </h3>
      <p
        class="mb-8 font-mono text-xs tracking-widest text-gray-500 uppercase dark:text-gray-400"
      >
        Select a topic to start a conversation
      </p>

      <div class="grid grid-cols-2 gap-4">
        {
          topicTiles.map((tile) => (
            <a
              href={`mailto:christian@conchari.com?subject=${encodeURIComponent(tile.subject)}`}
              class="group dark:bg-navy-light/30 dark:border-navy-light rounded-xl border border-gray-200 bg-white p-6 transition-all duration-300 hover:border-teal-500/50 hover:shadow-lg"
            >
              <Icon name={tile.icon} class="mb-3 h-6 w-6 text-teal-500" />
              <h4 class="mb-2 font-sans font-bold text-gray-800 dark:text-gray-100">
                {tile.title}
              </h4>
              <p class="text-sm leading-snug text-gray-500 dark:text-gray-400">
                {tile.description}
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Footer bar -->
  <div
    class="dark:border-navy-light mt-20 flex flex-col items-center justify-between gap-6 border-t border-gray-200 pt-10 md:flex-row"
  >
    <p class="font-mono text-xs tracking-widest text-gray-400 uppercase">
      &copy; 2026 Christian Conchari. All rights reserved.
    </p>
    <div class="flex items-center gap-3">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group dark:border-navy-light flex items-center gap-2 rounded-full border border-gray-200 px-3 py-1.5 transition-all duration-200 hover:border-teal-500/60 hover:bg-teal-500/5 dark:hover:border-teal-500/60"
          >
            <Icon
              name={link.icon}
              class="h-3.5 w-3.5 shrink-0 text-gray-400 transition-colors duration-200 group-hover:text-teal-500"
            />
            <span class="font-mono text-[10px] tracking-wide text-gray-400 transition-colors duration-200 group-hover:text-teal-500">
              {link.handle}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</SectionWrapper>
