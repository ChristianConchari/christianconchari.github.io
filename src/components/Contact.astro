---
import Icon from './Icon.astro';
import SectionWrapper from '../layouts/SectionWrapper.astro';
import SectionHeading from './ui/SectionHeading.astro';
import Card from './ui/Card.astro';
import Button from './ui/Button.astro';

const socialLinks = [
  {
    handle: '@christianconchari',
    icon: 'github',
    href: 'https://github.com/christianconchari',
  },
  {
    handle: '@chrisconchari',
    icon: 'linkedin',
    href: 'https://www.linkedin.com/in/chrisconchari',
  },
  { handle: '@ConchariChris', icon: 'x', href: 'https://x.com/ConchariChris' },
];

const topics = [
  {
    icon: 'rocket',
    title: 'Research Collaboration',
    description:
      "Working on an interesting machine learning initiative or academic paper? Let's explore how we can team up.",
  },
  {
    icon: 'megaphone',
    title: 'Speaking & Events',
    description:
      'Interested in having me share insights on AI or architecture at your upcoming meetup or academic event?',
  },
  {
    icon: 'code-brackets',
    title: 'Tech Consulting',
    description: 'Need deep-dive advice on ML architectures or system design?',
  },
  {
    icon: 'chat-bubble',
    title: 'Just Say Hi',
    description:
      "No specific agenda? I'm always down to connect with fellow builders and researchers.",
  },
];

const web3formsAccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY;
---

<SectionWrapper id="contact">
  <SectionHeading number="05" title="Contact" />

  <!-- Two-column grid -->
  <div class="grid grid-cols-1 gap-16 lg:grid-cols-2 lg:gap-24">
    <!-- Left Column -->
    <div>
      <p class="text-text-light dark:text-text-dark mb-4 leading-relaxed">
        Looking for a collaborator on your next research project? Interested in
        having me speak at your tech event, or need consulting for an upcoming
        AI initiative?
      </p>
      <p class="text-text-light dark:text-text-dark mb-8 leading-relaxed">
        I'm always open to connecting with fellow builders and sharing
        knowledge. I'll try my best to get back to you as soon as possible.
      </p>

      <!-- Topic cards (informational, form below is what actually sends the message) -->
      <div class="grid grid-cols-2 gap-4">
        {
          topics.map((topic) => (
            <Card class="rounded-xl">
              <Icon name={topic.icon} class="text-primary mb-3 h-6 w-6" />
              <h4 class="text-text-light dark:text-text-dark mb-2 font-mono font-bold">
                {topic.title}
              </h4>
              <p class="text-muted-light dark:text-muted-dark text-sm leading-snug">
                {topic.description}
              </p>
            </Card>
          ))
        }
      </div>
    </div>

    <!-- Right Column -->
    <div>
      <h3 class="text-text-light dark:text-text-dark mb-2 font-mono text-2xl font-bold">
        Send a message
      </h3>
      <p class="text-muted-light dark:text-muted-dark mb-8 font-mono text-xs tracking-widest uppercase">
        I'll get back to you by email
      </p>

      <form id="contactForm" class="flex flex-col gap-5">
        <input type="hidden" name="access_key" value={web3formsAccessKey} />
        <input type="checkbox" name="botcheck" class="hidden" style="display: none;" tabindex="-1" autocomplete="off" />

        <div>
          <label
            for="name"
            class="text-muted-light dark:text-muted-dark mb-1 block font-mono text-xs tracking-wider uppercase"
          >
            Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="text-text-light dark:text-text-dark dark:bg-navy-light/30 dark:border-navy-light focus:border-primary w-full rounded-lg border border-gray-200 bg-white px-4 py-2.5 outline-none transition-colors"
          />
        </div>

        <div>
          <label
            for="email"
            class="text-muted-light dark:text-muted-dark mb-1 block font-mono text-xs tracking-wider uppercase"
          >
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="text-text-light dark:text-text-dark dark:bg-navy-light/30 dark:border-navy-light focus:border-primary w-full rounded-lg border border-gray-200 bg-white px-4 py-2.5 outline-none transition-colors"
          />
        </div>

        <div>
          <label
            for="subject"
            class="text-muted-light dark:text-muted-dark mb-1 block font-mono text-xs tracking-wider uppercase"
          >
            Topic
          </label>
          <select
            id="subject"
            name="subject"
            class="text-text-light dark:text-text-dark dark:bg-navy-light/30 dark:border-navy-light focus:border-primary w-full rounded-lg border border-gray-200 bg-white px-4 py-2.5 outline-none transition-colors"
          >
            {
              topics.map((topic) => (
                <option
                  value={topic.title}
                  class="text-text-light dark:text-text-dark dark:bg-navy-light bg-white"
                >
                  {topic.title}
                </option>
              ))
            }
            <option value="Other" class="text-text-light dark:text-text-dark dark:bg-navy-light bg-white">
              Other
            </option>
          </select>
        </div>

        <div>
          <label
            for="message"
            class="text-muted-light dark:text-muted-dark mb-1 block font-mono text-xs tracking-wider uppercase"
          >
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="text-text-light dark:text-text-dark dark:bg-navy-light/30 dark:border-navy-light focus:border-primary w-full resize-none rounded-lg border border-gray-200 bg-white px-4 py-2.5 outline-none transition-colors"
          ></textarea>
        </div>

        <Button type="submit" id="contactSubmit" variant="solid" class="mt-2 w-full px-6 py-3">
          <Icon name="send" class="h-4 w-4" />
          <span>Send Message</span>
        </Button>

        <p id="contactStatus" class="hidden font-mono text-sm" role="status"></p>
      </form>
    </div>
  </div>

  <!-- Footer bar -->
  <div
    class="dark:border-navy-light mt-20 flex flex-col items-center justify-between gap-6 border-t border-gray-200 pt-10 md:flex-row"
  >
    <p class="text-muted-light dark:text-muted-dark font-mono text-xs tracking-widest uppercase">
      &copy; 2026 Christian Conchari. All rights reserved.
    </p>
    <div class="flex items-center gap-3">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group dark:border-navy-light hover:border-primary/60 hover:bg-primary/5 flex items-center gap-2 rounded-full border border-gray-200 px-3 py-1.5 transition-all duration-200"
          >
            <Icon
              name={link.icon}
              class="text-muted-light dark:text-muted-dark group-hover:text-primary h-3.5 w-3.5 shrink-0 transition-colors duration-200"
            />
            <span class="text-muted-light dark:text-muted-dark group-hover:text-primary font-mono text-[10px] tracking-wide transition-colors duration-200">
              {link.handle}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</SectionWrapper>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const submitButton = document.getElementById('contactSubmit') as HTMLButtonElement | null;
  const status = document.getElementById('contactStatus');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!submitButton || !status) return;

    submitButton.disabled = true;
    status.classList.remove('hidden', 'text-red-500', 'text-primary');
    status.textContent = 'Sending...';

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: new FormData(form),
      });
      const result = await response.json();

      if (response.ok && result.success) {
        status.classList.add('text-primary');
        status.textContent = "Thanks! Your message has been sent — I'll get back to you soon.";
        form.reset();
      } else {
        throw new Error(result.message || 'Something went wrong.');
      }
    } catch {
      status.classList.add('text-red-500');
      status.textContent = 'Failed to send. Please try again in a moment.';
    } finally {
      submitButton.disabled = false;
    }
  });
</script>
