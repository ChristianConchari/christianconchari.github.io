---
import Icon from './Icon.astro';
import Button from './ui/Button.astro';
---

<Button
  id="themeToggle"
  variant="outline"
  aria-label="Toggle theme"
  class="h-9 px-3 md:h-10 md:px-4 lg:h-[50px] lg:px-6"
>
  <!-- Sun icon (shown in dark mode) -->
  <span id="sunIcon" class="hidden dark:inline-flex"><Icon name="sun" class="h-5 w-5" /></span>
  <!-- Moon icon (shown in light mode) -->
  <span id="moonIcon" class="inline-flex dark:hidden"><Icon name="moon" class="h-5 w-5" /></span>
</Button>

<script>
  const themeToggle = document.getElementById('themeToggle');

  themeToggle?.addEventListener('click', () => {
    // Freeze all transitions for the duration of the theme switch
    document.documentElement.setAttribute('data-theme-switching', '');

    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');

    // Two rAFs: first lets the browser process the class change,
    // second confirms the repaint is committed before re-enabling transitions
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        document.documentElement.removeAttribute('data-theme-switching');
      });
    });
  });
</script>
